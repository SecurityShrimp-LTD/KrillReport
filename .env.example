# KrillReport configuration — copy to `.env` and edit.
# Every value here is optional; the tool runs with sane defaults and the
# "offline" LLM provider (no credentials, no network) out of the box.

# --- Filesystem layout ------------------------------------------------------
# Base directory for templates, uploads and generated reports. The templates/
# output/uploads sub-directories are derived from this unless set explicitly.
KRILLREPORT_DATA_DIR=krilldata
# KRILLREPORT_TEMPLATES_DIR=krilldata/templates
# KRILLREPORT_OUTPUT_DIR=krilldata/output
# KRILLREPORT_UPLOAD_DIR=krilldata/uploads

# --- Web server -------------------------------------------------------------
KRILLREPORT_HOST=127.0.0.1
KRILLREPORT_PORT=8000

# --- Logging ----------------------------------------------------------------
KRILLREPORT_LOG_LEVEL=INFO
# KRILLREPORT_LOG_FILE=krilldata/krillreport.log

# --- LLM narrative enhancement ---------------------------------------------
# Provider: offline | anthropic | openai | ollama
KRILLREPORT_LLM__PROVIDER=offline
# Leave model blank to use the provider default
# (anthropic=claude-opus-4-8, openai=gpt-4o, ollama=llama3.1).
KRILLREPORT_LLM__MODEL=
KRILLREPORT_LLM__MAX_TOKENS=2048
KRILLREPORT_LLM__TIMEOUT=90
KRILLREPORT_LLM__ENABLED=true
# For ollama or an OpenAI-compatible gateway, set the base URL:
# KRILLREPORT_LLM__BASE_URL=http://localhost:11434

# --- Provider credentials ---------------------------------------------------
# You can put the key in KRILLREPORT_LLM__API_KEY, or use each provider's native
# environment variable (the SDKs read these automatically):
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# KRILLREPORT_LLM__API_KEY=
